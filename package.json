{
  "name": "qfs-wallet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "server/index.mjs",
  "scripts": {
    "start": "node ./server/index.mjs",
    "start:prod": "npm run build && node ./server/index.mjs",
    "dev": "concurrently --kill-others \"npm run client:dev\" \"npm run api:dev\"",
    "client:dev": "vite",
    "api:dev": "node ./server/index.mjs",
    "build": "tsc && vite build",
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "node --test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/node": "^25.5.2",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.395.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
