# PostgreSQL connection string (required)
# Local dev: use your local postgres or Replit's built-in DB (DATABASE_URL is auto-set on Replit)
# Render: auto-injected from the linked PostgreSQL instance via render.yaml
DATABASE_URL=postgresql://user:password@localhost:5432/qfs_wallet

# JWT secret — minimum 32 characters, use a strong random string
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# Token expiry
ACCESS_TOKEN_TTL=12h
PENDING_TOKEN_TTL=10m

# Set to 'production' on Render, leave blank for local dev
NODE_ENV=development

# Optional: CoinGecko API keys for live market prices
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=
