# ─── Database ─────────────────────────────────────────────────────────────────
# Required. Set this manually in your hosting dashboard (Render, AAPanel, etc.)
# On Replit, DATABASE_URL is auto-set for you.
DATABASE_URL=postgresql://user:password@localhost:5432/zenvault

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Use a strong random string.
# Generate one at: https://randomkeygen.com
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# ─── Token expiry ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL=12h
PENDING_TOKEN_TTL=10m

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to 'production' on Render or VPS. Leave as 'development' for local dev.
NODE_ENV=development

# ─── CORS / Allowed Origins ───────────────────────────────────────────────────
# Required on VPS. Optional on Render (your .onrender.com subdomain is auto-allowed).
# Add your custom domain here. Separate multiple domains with a comma, no spaces.
# Example: https://zenvault.one,https://www.zenvault.one
ALLOWED_ORIGINS=

# ─── CoinGecko (optional) ─────────────────────────────────────────────────────
# Leave blank to use the free public API (rate-limited).
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=
